{
  "expo": {
    "name": "Ritual",
    "slug": "ritual",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0E1116",
    "splash": {
      "backgroundColor": "#0E1116"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ritual.app"
    },
    "android": {
      "package": "com.ritual.app",
      "adaptiveIcon": {
        "backgroundColor": "#0E1116",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "ritual",
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
